{
  "name": "caijing-showcase-site",
  "version": "1.0.0",
  "private": true,
  "description": "採景｜手機優先高級商品展示網站，Cloudflare Pages + Next.js + Tailwind + Pages Functions/D1/R2。",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
